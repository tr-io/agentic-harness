{
  "name": "@tr-io/harness",
  "version": "0.1.1",
  "description": "Agentic development harness for Claude Code projects",
  "type": "module",
  "bin": {
    "harness": "./dist/cli.js"
  },
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "lint": "biome check src",
    "lint:fix": "biome check --write src",
    "prepublishOnly": "npm run build"
  },
  "dependencies": {
    "commander": "^12.1.0"
  },
  "devDependencies": {
    "@biomejs/biome": "^1.9.4",
    "@types/node": "^22.0.0",
    "tsup": "^8.3.0",
    "typescript": "^5.6.0",
    "vitest": "^4.1.2",
    "inquirer": "^13.3.2"
  },
  "engines": {
    "node": ">=20.0.0"
  }
}
