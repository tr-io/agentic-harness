{
  "$schema": "https://raw.githubusercontent.com/tr-io/agentic-harness/main/schema.json",
  "version": "0.1.0",
  "project": {
    "name": "agentic-harness",
    "type": "cli",
    "stacks": ["typescript"],
    "entryPoints": ["./dist/cli.cjs", "src/cli.ts"],
    "testCommand": "npm test",
    "lintCommand": "npx biome check .",
    "typeCheckCommand": "npx tsc --noEmit",
    "buildCommand": "npm run build"
  },
  "integrations": {
    "linear": {
      "enabled": true,
      "teamKey": "TRI, the project is https://linear.app/triobox/project/agentic-harness-e3c80386917a/overview"
    }
  },
  "features": {
    "adr": true,
    "testingDocs": true,
    "completionReminder": true,
    "branchNamingWarning": true,
    "linterBootstrap": true,
    "linearIntegration": true,
    "artifactFreshnessCheck": true,
    "dddContextMaps": false,
    "latMd": false,
    "evaluatorQA": false,
    "autoLoop": true,
    "keelEnforcement": false
  },
  "hooks": {
    "prePush": {
      "lint": true,
      "typeCheck": true,
      "unitTest": true
    }
  }
}
